// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  id         String  @id @default(cuid())
  name       String
  email      String? @unique
  url        String?
  contact    BigInt?
  aboutMe    String
  image      String?
  clerk_id   String  @unique
  attributes Json?
}
